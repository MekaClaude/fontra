{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "sequences": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "stages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "stage": { "type": "integer" },
                "name": { "type": "string" },
                "glyphs": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "glyphs_first": { "type": "array", "items": { "type": "string" } },
                "glyphs_second": { "type": "array", "items": { "type": "string" } },
                "glyphs_third": { "type": "array", "items": { "type": "string" } },
                "glyphs_remainder": { "type": "array", "items": { "type": "string" } },
                "rationale": { "type": "string" },
                "completion_criteria": { "type": "string" },
                "unlocks": {
                  "type": "array",
                  "items": { "type": "integer" }
                },
                "alternatives": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "glyphs": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "rationale": { "type": "string" }
                    }
                  }
                }
              },
              "required": ["stage", "name", "completion_criteria"]
            }
          }
        },
        "required": ["id", "name", "stages"]
      }
    }
  },
  "required": ["version", "sequences"]
}
