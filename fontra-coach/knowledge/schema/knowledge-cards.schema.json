{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^(?:lc|uc|num|gen)-[A-Za-z0-9]+-[0-9]{3}$" },
          "glyph": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verbosity": { "type": "string", "enum": ["learner", "practitioner", "expert"] },
          "tips": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_cards": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sources": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "title", "body"]
      }
    }
  },
  "required": ["version", "cards"]
}
