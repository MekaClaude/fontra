{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]+-[0-9]+$"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "trigger_when": {
            "type": "string"
          },
          "applies_when": {
            "type": "string"
          },
          "knowledge": {
            "type": "string"
          },
          "magic_number": {
            "type": "number"
          },
          "tolerance": {
            "type": "number"
          },
          "tolerance_degrees": {
            "type": "number"
          },
          "tolerance_units": {
            "type": "number"
          },
          "auto_fix_available": {
            "type": "boolean"
          },
          "auto_fix_description": {
            "type": "string"
          },
          "fix_recommendation": {
            "type": "string"
          },
          "computation_method": {
            "type": "string"
          },
          "intent_detection": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "severity",
          "trigger_when"
        ]
      }
    }
  },
  "required": [
    "version",
    "thresholds"
  ]
}